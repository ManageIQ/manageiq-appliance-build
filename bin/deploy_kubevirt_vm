#!/bin/bash

set -Eeo pipefail

# Source shared functions
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/shared_kubevirt_functions.sh"

verify_prereq() {
    command -v oc > /dev/null 2>&1 || { log_error "oc cli must be installed"; exit 1; }
    command -v virtctl > /dev/null 2>&1 || { log_error "virtctl cli must be installed. See https://github.com/kubevirt/kubevirt/releases/latest"; exit 1; }

    oc whoami > /dev/null 2>&1 || { log_error "must be logged in to an OCP cluster"; exit 1; }
    [ -z "$(oc get storageclass --ignore-not-found)" ] && { log_error "OCP cluster must have a storageclass"; exit 1; }

    return 0
 }

# Function to generate random 8-character hex suffix
# Uses /dev/urandom and standard Unix tools (no openssl dependency)
generate_random_suffix() {
    LC_ALL=C tr -dc 'a-f0-9' < /dev/urandom | head -c 8
}

# Function to check for existing VM and prompt user
# Returns: 0 if no existing VM or user wants new deployment
#          1 if user wants to continue with existing VM (sets VM_NAME_BASE to existing name)
check_existing_vm() {
    local vm_base_name=$1

    # Only check if namespace exists, otherwise skip (will be created later)
    if ! oc get namespace "$NAMESPACE" >/dev/null 2>&1; then
        return 0
    fi

    # Check if any VMs exist with this base name (exact match or with suffix)
    local existing_vms=$(oc get vm -n "$NAMESPACE" 2>/dev/null | grep "^${vm_base_name}" | awk '{print $1}')

    if [[ -n "$existing_vms" ]]; then
        echo ""
        echo "WARNING: Found existing VM(s) with base name '${vm_base_name}':"
        echo "$existing_vms"
        echo ""
        echo "This may be from a previous deployment attempt."
        echo ""
        read -p "Do you want to resume the existing deployment? (y/n): " -n 1 -r
        echo ""

        if [[ $REPLY =~ ^[Yy]$ ]]; then
            local first_vm=$(echo "$existing_vms" | head -n 1)
            echo "Continuing with existing VM: $first_vm"
            # Strip -primary or -standby suffix if present to get the true base name
            local base_name="$first_vm"
            if [[ "$first_vm" =~ -primary$ ]]; then
                base_name="${first_vm%-primary}"
            elif [[ "$first_vm" =~ -standby$ ]]; then
                base_name="${first_vm%-standby}"
            fi
            export VM_NAME_BASE="$base_name"
            return 1  # Signal that we're using existing VM
        else
            log "Warning: Please delete the existing VM(s) first using: bin/delete_kubevirt_vm"
            exit 1
        fi
    fi

    return 0
}

# setup variables used in the script
env_setup() {
    # Load configuration from file (creates from template if needed)
    # Function will exit if config was just created or if error occurred
    load_kubevirt_config "config/kubevirt_vm_overrides.conf"

    # Check for existing VMs with this base name
    # If function returns 1, user wants to continue with existing VM (VM_NAME_BASE already set)
    # If function returns 0, proceed with new deployment (add random suffix)
    if check_existing_vm "$VM_NAME_BASE"; then
        # Add random suffix to VM_NAME_BASE to avoid SSH known_hosts conflicts
        # This ensures each deployment gets a unique VM name
        local random_suffix=$(generate_random_suffix)
        export VM_NAME_BASE="${VM_NAME_BASE}-${random_suffix}"
        echo "New deployment - VM base name will be: ${VM_NAME_BASE}"
    else
        echo "Resuming existing deployment - VM base name: ${VM_NAME_BASE}"
    fi

    export VM_NAME=$VM_NAME_BASE

    # Derived values (not from config file)
    export CLUSTER_URL=$(oc whoami --show-server | cut -d ':' -f 1,2)
    export CLUSTER_HOST=${CLUSTER_URL#https://api.}

    echo "Installing MIQ appliance using image url: ${IMAGE_NAME}"
    echo "Starting in 5 seconds... (Press Ctrl-C to cancel)"
    sleep 5

    RUNDATE=$(date '+%Y%m%d-%H%M%S')
    export LOG_FILE="/tmp/miq_appliance_configure_${RUNDATE}.log"

    echo "======================================================================"
    echo "ManageIQ Appliance Deployment Script"
    echo "======================================================================"
    echo "Log file: $LOG_FILE"
    echo "======================================================================"
    echo ""

    # remove kubevirt_host_files
    rm -f ~/.ssh/kubevirt_known_hosts
}

# Helper function to set VM-specific variables for primary/standby configurations
set_vm_variables() {
    local suffix=$1  # "primary" or "standby"

    if [[ -n "$suffix" ]]; then
        export VM_NAME="${VM_NAME_BASE}-${suffix}"
        export ROUTE_SUFFIX="${suffix}"
    else
        export VM_NAME="${VM_NAME_BASE}"
        export ROUTE_SUFFIX=""
    fi

    log "VM_NAME set to: $VM_NAME"
    log "ROUTE_SUFFIX set to: $ROUTE_SUFFIX"
}

log() {
    local message="$1"
    local datevalue=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[${datevalue}] ${message}" | tee -a $LOG_FILE
}

log_error() {
    local message="$1"
    log "ERROR: ${message}" >&2
    echo "See log file for details: $LOG_FILE" >&2
}

# Strip carriage returns from expect output to prevent terminal corruption
# Carriage returns can overwrite the current line and break subsequent command execution
strip_cr_from_expect_output() {
    tr -d '\r'
}

# Function to check if a command was successful and retry up to 3 times
check_command() {
    local retries=3
    local success=0
    for ((i=0; i<retries; i++)); do
        if [[ $? -eq 0 ]]; then
            success=1
            break
        else
            log "Command failed. Retrying in 5 seconds... (Attempt $((i+1)) of $retries)"
            sleep 5
        fi
    done

    if [[ $success -ne 1 ]]; then
        log_error "$1"
        return 1
    fi
    return 0
}

# Function to check if a resource exists
resource_exists() {
    local resource_kind=$1
    local resource_name=$2

    log "Checking if $resource_kind/$resource_name exists..."
    if ! oc get "$resource_kind" "$resource_name" &>/dev/null; then
        log "Resource $resource_kind/$resource_name does not exist."
        return 1
    fi
    log "Resource $resource_kind/$resource_name exists."
    return 0
}

create_datavolume_cr() {
    cat << EOF | oc apply -f -
apiVersion: cdi.kubevirt.io/v1beta1
kind: DataVolume
metadata:
  name: "${VM_NAME}"
spec:
  pvc:
    accessModes:
    - ReadWriteOnce
    resources:
      requests:
        storage: 80Gi
  source:
    http:
      url: "${IMAGE_NAME}"
      secretRef: ${SECRET_NAME}
EOF
    return $?
}

create_datavolume_db_cr() {
    cat << EOF | oc apply -f -
apiVersion: cdi.kubevirt.io/v1beta1
kind: DataVolume
metadata:
  name: "${VM_NAME}-database"
spec:
  source:
    blank: {}
  pvc:
    accessModes:
    - ReadWriteOnce
    resources:
      requests:
        storage: 5Gi
EOF
    return $?
}

create_vm_cr() {
    cat << EOF | oc apply -f -
apiVersion: kubevirt.io/v1
kind: VirtualMachine
metadata:
  labels:
    kubevirt.io/os: linux
  name: "${VM_NAME}"
spec:
  runStrategy: Always
  template:
    metadata:
      labels:
        kubevirt.io/domain: "${VM_NAME}"
    spec:
      domain:
        cpu:
          cores: 2
        devices:
          disks:
          - disk:
              bus: virtio
            name: disk0
          - disk:
              bus: virtio
            name: disk1
          - cdrom:
              bus: sata
              readonly: true
            name: cloudinitdisk
        machine:
          type: q35
        resources:
          requests:
            memory: 8Gi
      volumes:
      - name: disk0
        persistentVolumeClaim:
          claimName: "${VM_NAME}"
      - name: disk1
        persistentVolumeClaim:
          claimName: "${VM_NAME}-database"
      - cloudInitNoCloud:
          userData: |
            #cloud-config
            hostname: "${VM_NAME}"
            ssh_pwauth: True
            disable_root: false
            ssh_authorized_keys:
            - ${SSH_KEY}
        name: cloudinitdisk
EOF
    return $?
}

create_appliance_cockpit_route() {
    # Use VM_NAME directly for route name and host to make it obvious which VM uses this route
    local route_name="${VM_NAME}-cockpit"
    local route_host="${VM_NAME}-cockpit"

    cat << EOF | oc apply -f -
apiVersion: route.openshift.io/v1
kind: Route
metadata:
  name: ${route_name}
spec:
  host: ${route_host}.apps.${CLUSTER_HOST}
  port:
    targetPort: 9090
  tls:
    insecureEdgeTerminationPolicy: Redirect
    termination: passthrough
  to:
    kind: Service
    name: "${VM_NAME}-cockpit"
    weight: 100
  wildcardPolicy: None
EOF
    return $?
}

create_appliance_postgres_route() {
    # Use VM_NAME directly for route name and host to make it obvious which VM uses this route
    local route_name="${VM_NAME}-postgres"
    local route_host="${VM_NAME}-postgres"

    cat << EOF | oc apply -f -
apiVersion: route.openshift.io/v1
kind: Route
metadata:
  name: ${route_name}
spec:
  host: ${route_host}.apps.${CLUSTER_HOST}
  port:
    targetPort: 5432
  tls:
    insecureEdgeTerminationPolicy: Redirect
    termination: passthrough
  to:
    kind: Service
    name: "${VM_NAME}-postgres"
    weight: 100
  wildcardPolicy: None
EOF
    return $?
}

create_appliance_route() {
    # Use VM_NAME directly for route name and host to make it obvious which VM uses this route
    local route_name="${VM_NAME}-https"
    local route_host="${VM_NAME}"

    cat << EOF | oc apply -f -
apiVersion: route.openshift.io/v1
kind: Route
metadata:
  name: ${route_name}
spec:
  host: ${route_host}.apps.${CLUSTER_HOST}
  port:
    targetPort: 443
  tls:
    insecureEdgeTerminationPolicy: Redirect
    termination: passthrough
  to:
    kind: Service
    name: "${VM_NAME}-https"
    weight: 100
  wildcardPolicy: None
EOF
    return $?
}

# Function to install Kubevirt into the cluster
install_kubevirt() {
    log "Installing Kubevirt..."

    kubevirt_status=$(oc get kubevirt.kubevirt.io/kubevirt -o=jsonpath='{.status.phase}' -n kubevirt)
    if [[ "$kubevirt_status" == "Deployed" ]]; then
        log "KubeVirt is already installed."
        return 0
    fi

    log "Creating Kubevirt operator..."
    oc create -f https://github.com/kubevirt/kubevirt/releases/latest/download/kubevirt-operator.yaml > /dev/null 2>&1
    check_command "Failed to create Kubevirt operator." || return 1

    log "Creating Kubevirt CR..."
    oc create -f https://github.com/kubevirt/kubevirt/releases/latest/download/kubevirt-cr.yaml > /dev/null 2>&1
    check_command "Failed to create Kubevirt CR." || return 1

    log "Creating Kubevirt config map..."
    oc create configmap kubevirt-config --from-literal feature-gates=DataVolumes -n kube-system > /dev/null 2>&1
    check_command "Failed to create Kubevirt config map." || return 1

    log "Waiting for Kubevirt deployment..."
    local timeout=600
    local start_time=$(date +%s)
    while true; do
        kubevirt_status=$(oc get kubevirt.kubevirt.io/kubevirt -o=jsonpath='{.status.phase}' -n kubevirt)
        log "Current Kubevirt status: $kubevirt_status"
        if [[ "$kubevirt_status" == "Deployed" ]]; then
            break
        fi
        if [ $(($(date +%s) - start_time)) -ge $timeout ]; then
            log_error "Kubevirt deployment timed out after ${timeout} seconds."
            return 1
        fi
        sleep 5
    done

    log "Kubevirt deployed successfully."
    return 0
}

# Function to install CDI (Containerized Data Importer) into the cluster
install_cdi() {
    log "Installing CDI..."

    cdi_status=$(oc get cdi -n cdi -o=jsonpath='{.items[0].status.phase}')
    if [[ "$cdi_status" == "Deployed" ]]; then
        log "CDI is already installed."
        return 0
    fi

    log "Creating CDI operator..."
    oc create -f https://github.com/kubevirt/containerized-data-importer/releases/latest/download/cdi-operator.yaml > /dev/null 2>&1
    check_command "Failed to create CDI operator." || return 1

    log "Creating CDI CR..."
    oc create -f https://github.com/kubevirt/containerized-data-importer/releases/latest/download/cdi-cr.yaml > /dev/null 2>&1
    check_command "Failed to create CDI CR." || return 1

    log "Waiting for CDI deployment..."
    local timeout=600
    local start_time=$(date +%s)
    while true; do
        cdi_status=$(oc get cdi -n cdi -o=jsonpath='{.items[0].status.phase}')
        log "Current CDI status: $cdi_status"
        if [[ "$cdi_status" == "Deployed" ]]; then
            break
        fi
        if [ $(($(date +%s) - start_time)) -ge $timeout ]; then
            log_error "CDI deployment timed out after ${timeout} seconds."
            return 1
        fi
        sleep 5
    done

    log "CDI deployed successfully."
    return 0
}

# Function to create Namespace and Secret
create_namespace_and_secret(){
    log "Creating Namespace and Secret..."

    # Check if VM_NAME, NAMESPACE and SECRET_NAME is set
    if [[ -z "$VM_NAME" ]] || [[ -z "$NAMESPACE" ]] || [[ -z "$SECRET_NAME" ]]; then
        log_error "One or more required variables (VM_NAME, NAMESPACE, SECRET_NAME) are missing. Exiting..."
        return 1
    fi

    # Check if namespace exists
    if ! oc get namespace "$NAMESPACE" >/dev/null 2>&1; then
        log "Namespace $NAMESPACE does not exist. Creating..."
        if ! oc create namespace "$NAMESPACE"; then
            log_error "Namespace $NAMESPACE could not be created."
            return 1
        fi
        log "Namespace $NAMESPACE created successfully."
    else
        log "Namespace $NAMESPACE already exists."
    fi

    # Switch to namespace
    log "Switching to namespace $NAMESPACE..."
    if ! oc project "$NAMESPACE" >/dev/null 2>&1; then
        log_error "Could not switch to namespace $NAMESPACE."
        return 1
    fi
    log "Now in namespace $NAMESPACE."

    # Check if secret exists in the namespace
    if ! oc get secret "$SECRET_NAME" -n "$NAMESPACE" >/dev/null 2>&1; then
        log "Secret $SECRET_NAME does not exist in namespace $NAMESPACE. Creating..."
        if ! oc create secret generic "$SECRET_NAME" --from-literal=accessKeyId="$accessKeyId" --from-literal=secretKey="$secretKey" -n "$NAMESPACE"; then
            log_error "Secret $SECRET_NAME could not be created in namespace $NAMESPACE."
            return 1
        fi
        log "Secret $SECRET_NAME created successfully in namespace $NAMESPACE."
    else
        log "Secret $SECRET_NAME already exists in namespace $NAMESPACE."
    fi
    return 0
}

# Function to create DataVolume for Image and DB Disk
create_datavolume_and_pvc() {
    log "Creating DataVolume and PVC..."

    log "Applying DataVolume CR..."
    create_datavolume_cr
    check_command "Failed to create_datavolume_cr." || continue

    log "Applying DataVolume Database CR..."
    create_datavolume_db_cr
    check_command "Failed to create_datavolume_db_cr." || continue

    log "Waiting for data volumes to be bound and imported..."
    while true; do
        dv_status=$(oc get dv $VM_NAME -n $NAMESPACE -o=jsonpath='{.status.phase} ({.status.progress})')
        db_dv_status=$(oc get dv $VM_NAME-database -n $NAMESPACE -o=jsonpath='{.status.phase} ({.status.progress})')

        log "Data volume status: $dv_status, Database data volume status: $db_dv_status"

        if [[ "$dv_status" == "Succeeded"* && "$db_dv_status" == "Succeeded"* ]]; then
            log "Data volumes imported successfully."
            return 0
        fi

        sleep 20
    done
    return 0
}

# Function to create VirtualMachine fetch IP and VMI Name
create_virtualmachine_and_fetch_ip() {
    log "Fetching SSH key from $SECRET_NAME..."

    if [ -z "$SSH_KEY" ]; then
        log_error "Failed to fetch SSH key from the secret."
        return 1
    fi
    DECODED_SSH_KEY=$(echo "$SSH_KEY" | base64 --decode)
    log "SSH key fetched successfully."

    log "Creating VirtualMachine..."

    log "Calling create_vm_cr ..."
    create_vm_cr
    check_command "Failed to create VirtualMachine." || return 1

    log "Waiting for VirtualMachineInstance (VMI) to be running..."
    local timeout=600
    local start_time=$(date +%s)
    while true; do
        vmi_status=$(oc get vmi $VM_NAME -o=jsonpath='{.status.phase}' -n $NAMESPACE)
        log "Current VMI status: $vmi_status"
        if [[ "$vmi_status" == "Running" ]]; then
            break
        fi
        if [ $(($(date +%s) - start_time)) -ge $timeout ]; then
            log_error "VMI startup timed out after ${timeout} seconds."
            return 1
        fi
        sleep 5
    done

    # Get VMI name
    vmi_name=$(oc get vm $VM_NAME -o=jsonpath='{.metadata.name}' -n $NAMESPACE)
    if [[ -z "$vmi_name" ]]; then
        log_error "Failed to get VirtualMachine (VM) name. Exiting..."
        return 1
    fi

    log "VirtualMachine (VM) Name: $vmi_name"

    # Get VM IP
    log "Getting VirtualMachineInstance (VMI) IP address..."
    local ip_timeout=600

    local ip_start_time=$(date +%s)
    while true; do
        vmi_ip=$(oc get vmi $VM_NAME -o=jsonpath='{.status.interfaces[0].ipAddress}' -n $NAMESPACE)
        if [[ -n "$vmi_ip" ]]; then
            break
        fi
        if [ $(($(date +%s) - ip_start_time)) -ge $ip_timeout ]; then
            log_error "Failed to get VMI IP address after ${ip_timeout} seconds. Exiting..."
            return 1
        fi
        sleep 5
    done

    log "VM IP Address: $vmi_ip"
    return 0
}

# Function to create services for https, cockpit and SSH
create_services() {
    log "Creating services..."

    create_service_if_not_exists "$VM_NAME-https" "443" || return 1
    create_service_if_not_exists "$VM_NAME-cockpit" "9090" || return 1
    create_service_if_not_exists "$VM_NAME-ssh" "20222" || return 1
    create_service_if_not_exists "$VM_NAME-postgres" "5432" || return 1
    return 0
}

# Function to create a service if it does not exist
create_service_if_not_exists() {
    local service_name="$1"
    local service_port="$2"

    if ! resource_exists "svc" "$service_name"; then

        log "Creating service $service_name..."
        virtctl expose vmi $VM_NAME --port="$service_port" --name="$service_name" -n $NAMESPACE
        if ! check_command "Failed to expose service $service_name."; then
            return 1
        fi
        log "Service $service_name created successfully."
    else
        log "Service $service_name already exists. Skipping creation."
    fi
    return 0
}

# Function to create routes
create_routes() {
    log "Creating routes..."

    # Print the extracted cluster name
    log "Cluster host: $CLUSTER_HOST"

    # Ensure CLUSTER_HOST is set
    if [[ -z "$CLUSTER_HOST" ]]; then
        log_error "CLUSTER_HOST variable is missing. Exiting..."
        return 1
    fi

    # Create route for cockpit service
    log "Creating route for cockpit service..."

    create_appliance_cockpit_route
    create_appliance_postgres_route
    create_appliance_route

    log "Routes are created successfully."
    return 0
}

# Function to wait for SSH service to be ready and SSH into VM
ssh_into_vm() {
    local max_retries=60
    local retry=0
    local ssh_ready=false

    while [ $retry -lt $max_retries ]; do
        log "Checking SSH availability (attempt $((retry+1))/$max_retries)..."

        # Use expect to handle the SSH connection non-interactively
        ssh_test=$(expect -c "
            set timeout 5
            spawn virtctl ssh root@vmi/$vmi_name -n $NAMESPACE
            expect {
                \"Are you sure you want to continue connecting\" {
                    send \"no\r\"
                    expect eof
                }
                \"password:\" {
                    send \"\r\"
                    expect eof
                }
                \"Permission denied\" {
                    expect eof
                }
                timeout {
                    exit 1
                }
                eof {
                    exit 1
                }
            }
        " 2>&1 || true)

        # Check for various indicators that SSH is responding
        if echo "$ssh_test" | grep -qE "Are you sure you want to continue|password:|Permission denied"; then
            log "SSH service is responding"
            ssh_ready=true
            break
        fi

        sleep 10
        retry=$((retry+1))
    done

    if [ "$ssh_ready" = false ]; then
        log_error "SSH service did not become ready after $((max_retries * 10)) seconds"
        return 1
    fi

    log "SSH into the VM $vmi_name to change password..."
    ssh_output=$(expect <<EOF 2>&1
        set timeout 60
        set password smartvm
        set password_changed 0
        spawn virtctl ssh root@vmi/$vmi_name -n $NAMESPACE
        match_max 32000
        expect {
            -re "Are you sure you want to continue connecting.*\\?" {
                send "yes\r"
                exp_continue
            }
            "root@vmi.${vmi_name}.${NAMESPACE}'s password:" {
                send "\$password\r"
                exp_continue
            }
            "Permission denied, please try again." {
                send "$NEWPASSWORD\r"
                exp_continue
            }
            "You are required to change your password immediately" {
                exp_continue
            }
            "Your password has expired" {
                exp_continue
            }
            "New password:" {
                send "$NEWPASSWORD\r"
                exp_continue
            }
            "Retype new password:" {
                send "$NEWPASSWORD\r"
                set password_changed 1
                exp_continue
            }
            "passwd: all authentication tokens updated successfully" {
                set password_changed 1
                exp_continue
            }
            "#" {
                send "exit\r"
                expect eof
            }
            "Connection closed" {
                if {\$password_changed == 1} {
                    exit 0
                } else {
                    exit 1
                }
            }
            timeout {
                puts "ERROR: Timeout waiting for SSH response"
                exit 1
            }
            eof {
                if {\$password_changed == 1} {
                    exit 0
                } else {
                    puts "ERROR: Connection closed before password change completed"
                    exit 1
                }
            }
        }
        if {\$password_changed == 1} {
            exit 0
        } else {
            exit 1
        }
EOF
    )
    password_change_status=$?

    echo "$ssh_output" | strip_cr_from_expect_output | tee -a $LOG_FILE

    # Check if password change succeeded
    if [ $password_change_status -eq 0 ]; then
        log "SSH into VM succeeded and password is changed."
    else
        log_error "SSH into VM failed or password change did not complete"
        log_error "Please check the log output above for details"
        return 1
    fi
    return 0
}

# Function to set hostname and update /etc/hosts on the VM
set_hostname() {
    log "Setting hostname and updating /etc/hosts..."
    local setup_output=$(expect <<EOF 2>&1
        set timeout 60
        spawn virtctl ssh root@vmi/$vmi_name -n $NAMESPACE -c "hostnamectl set-hostname ${vmi_ip}.local && echo '${vmi_ip} ${vmi_ip}.local 192' >> /etc/hosts"
        match_max 32000
        expect {
            -re "Are you sure you want to continue connecting.*\\?" {
                send "yes\r"
                exp_continue
            }
            "root@vmi.${vmi_name}.${NAMESPACE}'s password: " {
                send "$NEWPASSWORD\r"
                exp_continue
            }
            eof
        }
EOF
    )
    echo "$setup_output" | strip_cr_from_expect_output >> $LOG_FILE
}

# Function to configure the appliance
# Parameters:
#   $1: replication_type - "none", "primary", or "standby"
#   $2: cluster_node_number - node number (1 for primary, 2 for standby)
#   $3: primary_host_ip - IP address of primary host (required for standby)
#   $4: standby_host_ip - IP address of standby host (required for standby)
configure_appliance() {
    local replication_type=${1:-"none"}
    local cluster_node_number=${2:-""}
    local primary_host_ip=${3:-""}
    local standby_host_ip=${4:-""}

    log "Configuring the appliance on VM $vmi_name (replication: $replication_type)..."

    set_hostname

    local cli_cmd="cd /var/www/miq/vmdb && bundle exec appliance_console_cli --region=55 --dbname=vmdb_production --username=root --password=smartvm --dbdisk=auto"

    if [[ "$replication_type" != "standby" ]]; then
        cli_cmd="$cli_cmd --internal --server start --key --message-server-config --message-server-host=${vmi_ip}.local --message-keystore-username=admin --message-keystore-password=smartvm"
    fi

    if [[ "$replication_type" == "primary" ]]; then
        log "Configuring as PRIMARY node (cluster node: $cluster_node_number)"
        cli_cmd="$cli_cmd --replication=primary --cluster-node-number=$cluster_node_number"
    elif [[ "$replication_type" == "standby" ]]; then
        log "Configuring as STANDBY node (cluster node: $cluster_node_number, primary: $primary_host_ip, standby: $standby_host_ip)"
        cli_cmd="$cli_cmd --fetch-key=$primary_host_ip --sshlogin=root --sshpassword=$NEWPASSWORD --replication=standby --cluster-node-number=$cluster_node_number --primary-host=$primary_host_ip --standby-host=$standby_host_ip"
    fi

    local temp_output=$(mktemp)

    # Build the remote command with proper exit status capture
    # Use a here-document to avoid complex escaping
    local remote_cmd=$(cat <<'REMOTE_CMD'
%CLI_CMD% 2>&1
EXIT_CODE=$?
echo "EXIT_STATUS=$EXIT_CODE"
exit $EXIT_CODE
REMOTE_CMD
)
    # Substitute the actual CLI command
    remote_cmd="${remote_cmd//%CLI_CMD%/$cli_cmd}"

    log "Full CLI command to execute:"
    log "$cli_cmd"
    log "Running appliance_console_cli..."

    (expect <<EOF
        set timeout 600
        log_user 1
        exp_internal 0

        spawn virtctl ssh root@vmi/$vmi_name -n $NAMESPACE -c {$remote_cmd}

        match_max 32000
        expect {
            -re "Are you sure you want to continue connecting.*\\?" {
                send "yes\r"
                exp_continue
            }
            "root@vmi.${vmi_name}.${NAMESPACE}'s password: " {
                send "$NEWPASSWORD\r"
                exp_continue
            }
            eof {
                catch wait result
                set exit_status [lindex \$result 3]
                exit \$exit_status
            }
            timeout {
                puts "ERROR: appliance_console_cli timed out after 10 minutes"
                exit 1
            }
        }
EOF
    ) > "$temp_output" 2>&1 &

    local expect_pid=$!
    local timeout_seconds=600
    local elapsed=0
    local sleep_interval=5

    while kill -0 $expect_pid 2>/dev/null; do
        if [ $elapsed -ge $timeout_seconds ]; then
            log_error "Configuration timed out after 10 minutes"
            kill -TERM $expect_pid 2>/dev/null
            sleep 2
            kill -KILL $expect_pid 2>/dev/null
            cat "$temp_output" | strip_cr_from_expect_output >> $LOG_FILE
            rm -f "$temp_output"
            return 1
        fi
        sleep $sleep_interval
        elapsed=$((elapsed + sleep_interval))
    done

    wait $expect_pid
    configure_status=$?

    local cleaned_output=$(cat "$temp_output" | strip_cr_from_expect_output)
    echo "$cleaned_output" >> $LOG_FILE

    # Extract the actual exit status from the remote command
    local remote_exit_status=$(echo "$cleaned_output" | grep "EXIT_STATUS=" | tail -1 | cut -d= -f2)

    rm -f "$temp_output"

    if [ $configure_status -ne 0 ]; then
        log_error "Appliance Configuration failed - SSH/expect error with exit code: $configure_status"
        return 1
    fi

    if [ -n "$remote_exit_status" ] && [ "$remote_exit_status" -ne 0 ]; then
        log_error "Appliance Configuration failed - appliance_console_cli returned exit code: $remote_exit_status"
        return 1
    fi

    if [ -z "$remote_exit_status" ]; then
        log_error "Appliance Configuration failed - could not determine exit status of appliance_console_cli"
        return 1
    fi

    log "Configuration on VM $vmi_name completed successfully."
    return 0
}

# Function to check evmserverd status with polling
check_evmserverd() {
    log "Checking evmserverd status..."

    local max_attempts=20
    local attempt=1

    while [ $attempt -le $max_attempts ]; do
        log "  Checking evmserverd status (attempt $attempt of $max_attempts)..."

        evmserverd_output=$(expect <<EOF 2>&1
        set timeout 30
        spawn virtctl ssh root@vmi/$VM_NAME -n $NAMESPACE
        expect "root@vmi/$VM_NAME.${NAMESPACE}'s password: "
        send "$NEWPASSWORD\r"
        expect "#"
        send "systemctl is-active evmserverd\r"
        expect -re "(inactive|active)"
        set status \$expect_out(1,string)
        send "exit\r"
        expect eof
        puts \$status
EOF
        )

        echo "$evmserverd_output" >> $LOG_FILE

        # Check if inactive first (error condition)
        if echo "$evmserverd_output" | grep -qw "inactive"; then
            log "  evmserverd is inactive (attempt $attempt of $max_attempts)"
        elif echo "$evmserverd_output" | grep -qw "active"; then
            log "Checking evmserverd status...completed successfully."
            return 0
        else
            log "  evmserverd status unknown (attempt $attempt of $max_attempts)"
        fi

        if [ $attempt -lt $max_attempts ]; then
            sleep 30
        fi

        attempt=$((attempt + 1))
    done

    log_error "evmserverd did not become active within 10 minutes"
    return 1
}

verify_env_prereq() {
    log "Setting up pre-deployment requirements..."

    install_kubevirt || { log_error "install_kubevirt failed"; exit 1; }
    install_cdi || { log_error "install_cdi failed"; exit 1; }
    create_namespace_and_secret || { log_error "create_namespace_and_secret failed"; exit 1; }

    log "Pre-deployment requirements completed successfully."
}

setup_vm_resources() {
    log "Setting up VM resources..."
    create_datavolume_and_pvc || { log_error "create_datavolume_and_pvc failed"; exit 1; }
    create_virtualmachine_and_fetch_ip || { log_error "create_virtualmachine_and_fetch_ip failed"; exit 1; }
    create_services || { log_error "create_services failed"; exit 1; }
    create_routes || { log_error "create_routes failed"; exit 1; }

    # Reset the initial ssh password
    ssh_into_vm || { log_error "ssh_into_vm failed"; exit 1; }

    log "Setting up VM resources...completed successfully."
}



verify_prereq
env_setup
verify_env_prereq

log "Starting MIQ Appliance Configuration Script..."

if [[ "$HA" == "true" ]]; then
    log "HA mode enabled - deploying primary VM..."
    set_vm_variables "primary"
else
    log "Standard mode - deploying single VM..."
fi

setup_vm_resources

# Deploy second VM if HA mode
if [[ "$HA" == "true" ]]; then
    # Store primary VM info for HA configuration (vmi_name and vmi_ip are set by setup_vm_resources)
    PRIMARY_VMI_NAME=$vmi_name
    PRIMARY_IP=$vmi_ip

    log "=== Configuring PRIMARY VM ==="
    configure_appliance "primary" "1" "" "" || exit 1
    check_evmserverd || { log_error "check_evmserverd failed"; exit 1; }
    log "Primary VM configuration completed successfully."

    log "=== Deploying STANDBY VM ==="
    set_vm_variables "standby"
    setup_vm_resources
    STANDBY_VMI_NAME=$vmi_name
    STANDBY_IP=$vmi_ip
    log "Standby VM setup completed successfully."

    log "=== Configuring STANDBY VM ==="
    configure_appliance "standby" "2" "$PRIMARY_IP" "$STANDBY_IP" || exit 1
    log "Standby VM configuration completed successfully (evmserverd check skipped for standby)."

    log "=== HA Deployment Complete ==="
    log "Full configuration log can be found at $LOG_FILE"
    log "Primary VM login: virtctl ssh root@vmi/$PRIMARY_VMI_NAME -n $NAMESPACE"
    log "Standby VM login: virtctl ssh root@vmi/$STANDBY_VMI_NAME -n $NAMESPACE"
else
    configure_appliance "none" "" "" "" || exit 1
    check_evmserverd || { log_error "check_evmserverd failed"; exit 1; }
    log "Standard deployment completed successfully."
    log "Full configuration log can be found at $LOG_FILE"
    log "To login: virtctl ssh root@vmi/$vmi_name -n $NAMESPACE"
fi

exit 0
