# KubeVirt VM Configuration
# This file contains default values for deploying and deleting KubeVirt VMs
# Copy this file to kubevirt_vm_overrides.conf (without .tmpl) and customize as needed
# Format: Simple shell variable assignments (KEY=value)

# Namespace where the VM resources will be created
NAMESPACE=miq-appliance

# Root password for the VM (used for initial login and configuration)
NEWPASSWORD=smartvm123

# Secret name for storing image access credentials
SECRET_NAME=miq-appliance-secret

# Image access credentials (used if the image requires authentication)
accessKeyId=dummy
secretKey=dummypassword

# SSH public key (base64 encoded) for SSH access to the VM
# If not provided or left as dummy, you can login using root password
# This is an invalid or dummy key for security reasons.
SSH_

# High Availability mode - if true, deploy primary and standby VMs
HA=false

# Base name for the VM (will be suffixed with -primary/-standby in HA mode)
VM_NAME_BASE=manageiq-ovirt-devel

# URL to the ManageIQ image
IMAGE_NAME=https://releases.manageiq.org/manageiq-ovirt-devel.qc2
